# Auto-load the project virtual environment.
# Requires direnv: https://direnv.net/

# Re-evaluate when the venv bootstrap changes.
watch_file scripts/venv.rc

# Bootstrap + install deps (creates ./.venv if missing).
source scripts/venv.rc

# Ensure direnv reliably tracks the venv in your shell.
export VIRTUAL_ENV="$PWD/.venv"
PATH_add "$VIRTUAL_ENV/bin"

# Application settings
export PORT=8088
export PUBLIC_URL="https://ocr.reb00t.io"

# Local credentials (not committed)
watch_file .envrc.local
if [ -f .envrc.local ]; then
  source_env .envrc.local
fi
